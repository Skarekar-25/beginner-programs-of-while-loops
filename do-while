#Sum of even digits and sum of odd digits

n=int(input("enter a number:"))
even_total = 0
odd_total = 0

while True:
  digits = n%10
  if digits%2==0:
    even_total+=digits
  else:
    odd_total+=digits

  n//=10

  if n==0:
    break

print("Even total = ",even_total)
print("Odd total = ",odd_total)

