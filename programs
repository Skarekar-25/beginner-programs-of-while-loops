#armstrong number 
n = int(input("enter a number: "))

temp = n
digits = len(str(n))
sum = 0

while n>0 :
  digit = n%10
  sum+=digit**digits
  n//=10

if temp == sum:
  print("armstrong number")
else:
  print("not armstrong")

  #perfect number 
n = int(input("enter a number:"))

sum = 0
i = 1

while i<n:
  if n%i == 0:
    sum+=i
  i=i+1

if sum == n:
  print("perfect number")
else:
  print("not perfect")

